#!/usr/bin/env node
// lander — lets an in-task agent call back into the lander server, and (via the
// internal `run` command) is the detached process the server launches to drive
// one claude turn.
// Identity is injected when the server runs a turn: LANDER_API, LANDER_PROJECT,
// LANDER_TASK, and LANDER_TOKEN (the per-task secret that authenticates these
// callbacks).
import { spawn, spawnSync } from 'node:child_process'
import { createWriteStream, readFileSync, writeFileSync } from 'node:fs'
import { pathToFileURL } from 'node:url'

const {
  LANDER_API: API,
  LANDER_PROJECT: PROJECT,
  LANDER_TASK: TASK,
  LANDER_TOKEN: TOKEN,
} = process.env

const die = (m) => {
  console.error(`lander: ${m}`)
  process.exit(1)
}

async function call(project, path, init) {
  if (!API) die('not inside a lander task (LANDER_API unset)')
  // Identify the calling task so the server can authenticate it (e.g. to cap
  // the permissions a spawned task may be granted to this task's own). Sent on
  // every call; only permission-sensitive endpoints consult it.
  const auth = {}
  if (TASK) auth['x-lander-task'] = TASK
  if (PROJECT) auth['x-lander-project'] = PROJECT
  if (TOKEN) auth['x-lander-token'] = TOKEN
  const res = await fetch(`${API}/api/${project}${path}`, {
    ...init,
    headers: { 'content-type': 'application/json', ...auth, ...init?.headers },
  })
  const body = await res.json().catch(() => ({}))
  if (!res.ok) die(body.error || `${res.status} ${res.statusText}`)
  return body
}

async function setStatus(status, { quiet = false } = {}) {
  if (!TASK) die('no current task (LANDER_TASK unset)')
  await call(PROJECT, `/tasks/${TASK}`, {
    method: 'PATCH',
    body: JSON.stringify({ status }),
  })
  // `land` stays silent on success. It's terminal, so a "status → landed"
  // confirmation does nothing but invite the agent to echo it back — the
  // trailing "Landed." we're trying to kill. Nothing to react to, nothing to
  // say. Failures still surface via die(); wedge keeps its line since the
  // agent works on past it.
  if (!quiet) console.log(`status → ${status}`)
}

async function readStdin() {
  const chunks = []
  for await (const c of process.stdin) chunks.push(c)
  return Buffer.concat(chunks).toString('utf8')
}

// --date (a date/time the server parses) and --time (minutes from now) both set
// a wakeup time; they're mutually exclusive, and --time must be a positive
// number. Shared by `launch` (where a wakeup is optional), `rest`, and `send`.
// --await (a wakeup *condition* — other tasks landing) is orthogonal and may
// combine with either, so it isn't checked here; see resolveAwait.
function validateSchedule(o) {
  if (o.date != null && o.time != null)
    die('--date and --time are mutually exclusive')
  if (o.time != null && !(Number.isFinite(o.time) && o.time > 0))
    die('--time expects a positive number of minutes')
}

// Resolve a comma-separated --await value (task ids or unambiguous prefixes) to
// full ids, so the server stores canonical ids. `self` rejects a task awaiting
// itself (a deadlock). Returns the resolved ids, or undefined when no --await.
async function resolveAwait(value, { self } = {}) {
  if (value == null) return undefined
  const parts = value
    .split(',')
    .map((s) => s.trim())
    .filter(Boolean)
  if (!parts.length) die('--await expects one or more task ids')
  const ids = []
  for (const p of parts) {
    const id = await resolveId(p)
    if (self && id === self) die('a task cannot await itself')
    ids.push(id)
  }
  return ids
}

async function launchTask(rest) {
  const o = { project: PROJECT, allowEdits: false, allowCommits: false }
  const pos = []
  for (let i = 0; i < rest.length; i++) {
    const a = rest[i]
    if (a === '--project') o.project = rest[++i]
    else if (a === '--message') o.message = rest[++i]
    else if (a === '--title') o.title = rest[++i]
    else if (a === '--date') o.date = rest[++i]
    else if (a === '--time') o.time = Number(rest[++i])
    else if (a === '--await') o.await = rest[++i]
    else if (a === '--edits') o.allowEdits = true
    else if (a === '--commits') o.allowCommits = true
    else pos.push(a)
  }
  // The server caps the requested --edits/--commits to what this (spawning)
  // task holds, authenticating us by the caller headers `call` attaches; a task
  // can't grant a child access it lacks.
  o.message ??= pos.shift()
  if (o.message === '-') o.message = await readStdin()
  if (!o.message?.trim()) die('usage: lander launch <message>')
  validateSchedule(o)
  // --await defers the launch until the named tasks land (resolved to full ids
  // here); combinable with --date/--time, in which case launch fires on
  // whichever trigger comes first.
  o.await = await resolveAwait(o.await)
  // --title sets the name directly; without it the server asks haiku. --date or
  // --wait defers the launch (a date/time the server parses, or N minutes from
  // now) and the server runs the task then.
  const task = await call(o.project, '/tasks', {
    method: 'POST',
    body: JSON.stringify(o),
  })
  console.log(task.session) // print new task id for the orchestrator to track
}

// Put the current task to rest with a scheduled wakeup. Takes the same
// --date/--time flags as `launch`, but one is required (a wakeup needs a time).
// The server flips the task to resting, records a `scheduled` event, and wakes
// it at that time with a generated "Resumed at …" message.
async function restTask(args) {
  if (!TASK) die('no current task (LANDER_TASK unset)')
  const o = {}
  for (let i = 0; i < args.length; i++) {
    const a = args[i]
    if (a === '--date') o.date = args[++i]
    else if (a === '--time') o.time = Number(args[++i])
    else if (a === '--await') o.await = args[++i]
    else die(`rest: unexpected argument ${a}`)
  }
  if (o.date == null && o.time == null && o.await == null)
    die('usage: lander rest (--date <when> | --time <minutes> | --await <ids>)')
  validateSchedule(o)
  o.await = await resolveAwait(o.await, { self: TASK })
  await call(PROJECT, `/tasks/${TASK}/rest`, {
    method: 'POST',
    body: JSON.stringify(o),
  })
  console.log('resting')
}

// Resolve a task id from a full id or any unambiguous prefix (so an agent can
// paste the short id `lander list` prints). Matches within the caller's project.
// `archived` resolves among archived tasks instead of active ones (for restore).
async function resolveId(idOrPrefix, { archived = false } = {}) {
  if (!idOrPrefix) die('a task id is required')
  const tasks = await call(PROJECT, `/tasks${archived ? '?archived=1' : ''}`, {
    method: 'GET',
  })
  const pool = archived ? tasks.filter((t) => t.archived) : tasks
  const matches = pool.filter((t) => t.session.startsWith(idOrPrefix))
  if (matches.length === 0) die(`no task matching ${idOrPrefix}`)
  if (matches.length > 1)
    die(`ambiguous task id ${idOrPrefix} (${matches.length} matches)`)
  return matches[0].session
}

// `lander list [--status <s>] [--json]` — the project's tasks, newest first.
async function listTasks(args) {
  let status
  let json = false
  for (let i = 0; i < args.length; i++) {
    const a = args[i]
    if (a === '--status') status = args[++i]
    else if (a === '--json') json = true
    else die(`list: unexpected argument ${a}`)
  }
  let tasks = await call(PROJECT, '/tasks', { method: 'GET' })
  if (status) tasks = tasks.filter((t) => t.status === status)
  if (json) return void console.log(JSON.stringify(tasks, null, 2))
  if (!tasks.length) return void console.log('(no tasks)')
  for (const t of tasks) {
    const sched = t.scheduledFor ? `  ⏰ ${t.scheduledFor}` : ''
    console.log(
      `${t.session.slice(0, 8)}  ${t.status.padEnd(7)}  ${t.title}${sched}`,
    )
  }
}

// `lander view <id> [--json]` — one task's status and recent conversation.
async function viewTask(args) {
  let json = false
  const pos = []
  for (const a of args) {
    if (a === '--json') json = true
    else pos.push(a)
  }
  if (!pos[0]) die('usage: lander view <id>')
  const id = await resolveId(pos[0])
  const task = await call(PROJECT, `/tasks/${id}`, { method: 'GET' })
  if (json) return void console.log(JSON.stringify(task, null, 2))
  console.log(`${task.title}  [${task.status}]`)
  console.log(`id: ${task.session}`)
  if (task.scheduledFor) console.log(`scheduled: ${task.scheduledFor}`)
  console.log(`edits: ${task.allowEdits}  commits: ${task.allowCommits}`)
  for (const m of task.messages.slice(-6)) {
    const text = m.text.length > 600 ? `${m.text.slice(0, 600)}…` : m.text
    console.log(`\n${m.role}:\n${text}`)
  }
}

// `lander send <id> <message|-> [--date <when> | --wait <minutes>]` — message
// another task in this project. Without a schedule the message is delivered now
// (queued behind any in-flight turn); --date/--wait defer delivery to that time.
async function sendTask(args) {
  const o = {}
  const pos = []
  for (let i = 0; i < args.length; i++) {
    const a = args[i]
    if (a === '--date') o.date = args[++i]
    else if (a === '--time') o.time = Number(args[++i])
    else if (a === '--await') o.await = args[++i]
    else pos.push(a)
  }
  const target = pos.shift()
  if (!target) die('usage: lander send <id> <message>')
  let message = pos.shift()
  if (message === '-') message = await readStdin()
  if (!message?.trim()) die('usage: lander send <id> <message|->')
  validateSchedule(o)
  const awaitIds = await resolveAwait(o.await)
  const id = await resolveId(target)
  await call(PROJECT, `/tasks/${id}/messages`, {
    method: 'POST',
    body: JSON.stringify({ message, date: o.date, time: o.time, await: awaitIds }),
  })
  const verb =
    o.date != null || o.time != null || o.await != null ? 'scheduled' : 'sent'
  console.log(`${verb} → ${id.slice(0, 8)}`)
}

// `lander archive <id...> [--restore]` — move one or more tasks out of the list
// into the project's archived/ dir (or back, with --restore). Archiving needs a
// non-riding task; the server rejects a riding one. Resolves a full id or an
// unambiguous prefix — among active tasks to archive, among archived ones to
// restore.
async function archiveTask(args) {
  let restore = false
  const pos = []
  for (const a of args) {
    if (a === '--restore') restore = true
    else pos.push(a)
  }
  if (!pos[0]) die('usage: lander archive <id...> [--restore]')
  for (const arg of pos) {
    const id = await resolveId(arg, { archived: restore })
    await call(PROJECT, `/tasks/${id}/archive`, {
      method: 'POST',
      body: JSON.stringify({ archived: !restore }),
    })
    console.log(`${restore ? 'restored' : 'archived'} → ${id.slice(0, 8)}`)
  }
}

// `lander run <jobfile>` — the detached turn runner the server launches (not for
// agents). It owns the claude child, appends its raw stream-json stdout to the
// run's log, and records its identity once (lease.json: pid + start time) and
// completion (done.json). The server only ever reads these files, so the agent
// keeps working even if the server restarts mid-turn. Everything it needs comes
// from the job file; it ignores the LANDER_* identity env above — that identity
// is injected into claude through the job's own `env`.
async function runJob(args) {
  const jobPath = args[0]
  if (!jobPath) die('usage: lander run <jobfile>')
  let job
  try {
    job = JSON.parse(readFileSync(jobPath, 'utf8'))
  } catch (e) {
    die(`run: cannot read job ${jobPath}: ${e.message}`)
  }

  // Record our identity once, before spawning, so a reattaching server finds the
  // pid immediately. The server tells a live runner from a recycled pid by
  // matching this start time against the one the OS reports for the pid.
  const startedAt = new Date().toISOString()
  try {
    writeFileSync(
      job.leasePath,
      JSON.stringify({ pid: process.pid, startedAt }),
    )
  } catch {}

  const log = createWriteStream(job.logPath, { flags: 'a' })
  let stderr = ''
  let settled = false
  let interrupted = false
  const finish = (exitCode) => {
    if (settled) return
    settled = true
    clearTimeout(timer)
    // Flush the log, then record completion so the server's reducer finalizes
    // the turn (and surfaces a non-zero exit, with stderr, as an error reply).
    // `interrupted` marks a deliberate stop (the server wedged a riding task);
    // the reducer treats it as a clean finish rather than a crash.
    log.end(() => {
      try {
        writeFileSync(
          job.donePath,
          JSON.stringify({
            exitCode,
            interrupted,
            stderr: stderr.trim(),
            endedAt: new Date().toISOString(),
          }),
        )
      } catch {}
      process.exit(0)
    })
  }

  const child = spawn('claude', job.claudeArgs, {
    cwd: job.cwd,
    env: { ...process.env, ...job.env },
    stdio: ['ignore', 'pipe', 'pipe'],
  })

  // Kill the run after the idle window with no output; a still-streaming turn
  // resets the clock and keeps going.
  let timer
  const arm = () => {
    clearTimeout(timer)
    timer = setTimeout(() => child.kill('SIGKILL'), job.idleTimeoutMs)
  }
  arm()

  child.stdout.on('data', (chunk) => {
    arm()
    log.write(chunk)
  })
  child.stderr.on('data', (chunk) => {
    arm()
    stderr += chunk.toString()
  })
  child.on('error', (e) => {
    stderr += `error running claude: ${e.message}`
    finish(1)
  })
  child.on('close', (code) => finish(code == null ? 1 : code))

  // The server sends SIGTERM to interrupt a riding turn — the human wedged the
  // task out from under the agent. Stop claude and finish cleanly, recording the
  // partial reply already streamed to the log. We're our own process-group
  // leader, so this signal is meant for us and us alone.
  process.on('SIGTERM', () => {
    interrupted = true
    try {
      child.kill('SIGKILL')
    } catch {}
    finish(0)
  })
}

// --- assist ----------------------------------------------------------------
// Run a one-shot `claude -p` session and return its reply. The prompt comes
// first; any further args are appended on their own line as the material to act
// on, so `lander assist "summarize:" "$(cat notes)"` sends the prompt then the
// notes. A non-zero exit from claude aborts. Shared by the `lander assist` CLI
// command and the `lander.assist()` flow API.
function runClaude(prompt, args) {
  const text = args.length ? `${prompt}\n${args.join('')}` : prompt
  // `--` so a prompt starting with a hyphen is taken as the positional prompt
  // rather than parsed as an option by claude's CLI.
  const r = spawnSync('claude', ['-p', '--', text], { encoding: 'utf8' })
  if (r.error) die(`assist: ${r.error.message}`)
  if (r.status !== 0)
    die(`assist: ${(r.stderr || '').trim() || `claude exited ${r.status}`}`)
  return r.stdout ?? ''
}

// `lander assist <prompt> [text …]` — print the assistant's reply to stdout.
async function assist(args) {
  const [prompt, ...rest] = args
  if (!prompt) die('usage: lander assist <prompt> [text …]')
  process.stdout.write(runClaude(prompt, rest))
}

// --- flows -----------------------------------------------------------------
// A flow is a JS script at data/<project>/flows/<name>.js exporting a default
// async function. `lander flow <name> [--key value …]` resolves the script's
// path from the server, imports it in this process, and calls it with a `lander`
// object — the same self-management surface as the CLI, but as awaitable methods
// (so `view` hands back a parsed task, not text to re-parse). The --key value
// pairs become the flow's `lander.inputs`.

// Run `command` under `sh` with the args as its positional params ($1, $2, …;
// "$@" for all) and return its stdout. A non-zero exit aborts the flow.
function runShell(command, args) {
  const r = spawnSync('sh', ['-c', command, 'sh', ...args], { encoding: 'utf8' })
  if (r.error) die(`shell: ${r.error.message}`)
  if (r.status !== 0)
    die(`shell: ${(r.stderr || '').trim() || `exited ${r.status}`}`)
  return r.stdout ?? ''
}

// The `lander` object handed to a flow script. Server-backed methods (launch,
// send, view, list, status, land, wedge, rest) call the same API the CLI does;
// assist/shell run a local child; flow nests. Methods naming another task
// resolve a full id or unambiguous prefix, like the CLI.
function makeLander(inputs) {
  return {
    inputs,
    async launch(message, opts = {}) {
      if (!message?.trim()) die('lander.launch: a message is required')
      const o = {
        project: opts.project ?? PROJECT,
        message,
        title: opts.title,
        date: opts.date,
        time: opts.time,
        allowEdits: !!opts.edits,
        allowCommits: !!opts.commits,
      }
      validateSchedule(o)
      o.await = await resolveAwait(opts.await)
      const task = await call(o.project, '/tasks', {
        method: 'POST',
        body: JSON.stringify(o),
      })
      return task.session // the new task's id
    },
    async send(target, message, opts = {}) {
      if (!message?.trim()) die('lander.send: a message is required')
      validateSchedule(opts)
      const awaitIds = await resolveAwait(opts.await)
      const id = await resolveId(target)
      await call(PROJECT, `/tasks/${id}/messages`, {
        method: 'POST',
        body: JSON.stringify({
          message,
          date: opts.date,
          time: opts.time,
          await: awaitIds,
        }),
      })
      return id
    },
    async view(target) {
      const id = await resolveId(target)
      return call(PROJECT, `/tasks/${id}`, { method: 'GET' })
    },
    async list(opts = {}) {
      const tasks = await call(PROJECT, '/tasks', { method: 'GET' })
      return opts.status ? tasks.filter((t) => t.status === opts.status) : tasks
    },
    land: () => setStatus('landed', { quiet: true }),
    wedge: () => setStatus('wedged'),
    async rest(opts = {}) {
      const o = { date: opts.date, time: opts.time }
      validateSchedule(o)
      o.await = await resolveAwait(opts.await, { self: TASK })
      if (o.date == null && o.time == null && o.await == null)
        die('lander.rest: pass date, time, or await')
      await call(PROJECT, `/tasks/${TASK}/rest`, {
        method: 'POST',
        body: JSON.stringify(o),
      })
    },
    assist: (prompt, ...args) => runClaude(prompt, args).trim(),
    shell: (command, ...args) => runShell(command, args).trim(),
    flow: (name, inputs = {}) => runFlowByName(name, inputs),
  }
}

// Resolve a flow's path from the server, import it, and run its default export.
async function runFlowByName(name, inputs) {
  const { path: file } = await call(
    PROJECT,
    `/flows/${encodeURIComponent(name)}`,
  )
  const mod = await import(pathToFileURL(file).href)
  if (typeof mod.default !== 'function')
    die(`flow "${name}" must export a default async function`)
  return mod.default(makeLander(inputs))
}

// `lander flow <name> [--key value …]` — the --key value pairs become inputs.
async function runFlow(args) {
  const name = args[0]
  if (!name) die('usage: lander flow <name> [--key value …]')
  const inputs = {}
  for (let i = 1; i < args.length; i++) {
    const a = args[i]
    if (!a.startsWith('--')) die(`flow: unexpected argument "${a}"`)
    inputs[a.slice(2)] = args[++i] ?? ''
  }
  await runFlowByName(name, inputs)
}

// --- bash-guard (PreToolUse hook) ------------------------------------------
// Wired in by the server as a PreToolUse hook on the Bash tool (see
// buildClaudeArgs). claude pipes the tool call as JSON on stdin; when the agent
// runs a Bash command with run_in_background set, we attach an advisory note
// explaining that the job won't outlive the turn — it's a child of this turn's
// claude, reaped when the turn ends, and lander never consumes its completion,
// so it can't wake the task ("you'll be notified when it completes" only holds
// in interactive mode, not lander's turn-based one). The note steers toward the
// mechanisms that do persist: `lander rest` to wait, `lander launch` for parallel
// agentic work.
//
// Crucially this is advisory only: we emit `additionalContext` and set NO
// permissionDecision, so the normal permission flow is untouched — run_in_background
// never grants access the same command wouldn't have in the foreground. Anything
// else passes straight through. A malformed payload never interferes.
async function bashGuard() {
  let input
  try {
    input = JSON.parse((await readStdin()) || '{}')
  } catch {
    return // malformed payload — don't interfere with the tool call
  }
  if (input.tool_name !== 'Bash' || input.tool_input?.run_in_background !== true)
    return
  const context =
    'Heads-up: this background job will not survive the turn. A backgrounded ' +
    "process is a child of this turn's claude; when the turn ends it is reaped, " +
    'and lander never consumes its completion, so it cannot wake the task — the ' +
    'job just leaks. Background it only for work you will consume within THIS ' +
    'turn. If you need to wait for something, end the turn and resume later with ' +
    '`lander rest --time <minutes>` / `--date <when>` / `--await <ids>`. For ' +
    'parallel agentic work, spawn a sibling task with `lander launch <message>`. ' +
    '(A turn-scoped co-process verb is planned for jobs that must outlive a turn.)'
  process.stdout.write(
    JSON.stringify({
      hookSpecificOutput: {
        hookEventName: 'PreToolUse',
        additionalContext: context,
      },
    }),
  )
}

const [cmd, ...rest] = process.argv.slice(2)
const run = {
  land: () => setStatus('landed', { quiet: true }),
  wedge: () => setStatus('wedged'),
  rest: () => restTask(rest),
  launch: () => launchTask(rest),
  list: () => listTasks(rest),
  view: () => viewTask(rest),
  send: () => sendTask(rest),
  archive: () => archiveTask(rest),
  assist: () => assist(rest),
  flow: () => runFlow(rest),
  run: () => runJob(rest),
  'bash-guard': () => bashGuard(),
}[cmd]
if (!run)
  die(
    `unknown command: ${cmd ?? '(none)'} — try ` +
      'land | wedge | rest (--date|--time|--await) | ' +
      'launch <message> | list | view <id> | send <id> <message> | ' +
      'archive <id...> [--restore] | assist <prompt> | flow <name>',
  )
run().catch((e) => die(e.message))
